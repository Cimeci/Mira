# Copie ce fichier en .env.local (jamais commité — voir .gitignore).
# Partage les vraies valeurs via le Discord équipe, PAS sur git.
# Le squelette (mocks) tourne SANS aucune de ces clés.

# LLM — rédaction de la notice DSA / instructions du locator
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Auto-login de l'agent (quand il détecte un formulaire de connexion).
# Défaut = identifiants du login MOCK de démo. NE mets PAS ici les identifiants
# d'une plateforme tierce : G-12 (cible = mock host uniquement) + ToS + risque de ban.
MIRA_LOGIN_EMAIL=demo@project-mira.example
MIRA_LOGIN_PASSWORD=mira-demo

# Stage 2 — détecteur de média synthétique (deepfake)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
DEEPFAKE_SCORE_THRESHOLD=0.85

# Stage 3 — dispatch de la notice (vers l'inbox de démo uniquement)
RESEND_API_KEY=
SENDGRID_API_KEY=
NOTICE_SENDER_EMAIL=notice@exemple.eu
DEMO_TARGET_INBOX=

# Preuve / rétention (RGPD)
EVIDENCE_ENCRYPTION_KEY=
EVIDENCE_RETENTION_DAYS=90

# DB — Supabase (projet équipe ; valeurs via le Discord, jamais sur git)
# URL + clés : dashboard Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Clé secrète — côté SERVEUR uniquement, jamais exposée au front/navigateur.
SUPABASE_SERVICE_ROLE_KEY=
# Connexion Postgres directe (migrations, psql) : Settings → Database. Optionnel.
SUPABASE_DB_URL=
