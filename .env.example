# Copie ce fichier en .env.local (jamais commité — voir .gitignore).
# Partage les vraies valeurs via le Discord équipe, PAS sur git.
# Le squelette (mocks) tourne SANS aucune de ces clés.

# LLM — rédaction de la notice DSA / instructions du locator
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Modèle Computer Use (défaut : gemini-3-flash-preview). Décommente pour basculer
# vers la 2.5 si un environnement ne sert pas encore la 3.
# MIRA_CU_MODEL=gemini-2.5-computer-use-preview-10-2025

# Auto-login de l'agent (quand il détecte un formulaire de connexion).
# Défaut = identifiants du login MOCK de démo. NE mets PAS ici les identifiants
# d'une plateforme tierce : G-12 (cible = mock host uniquement) + ToS + risque de ban.
MIRA_LOGIN_EMAIL=demo@project-mira.example
MIRA_LOGIN_PASSWORD=mira-demo

# Locator (Computer Use) — mode visible pour le tracking/debug.
# MIRA_HEADED=1 → ouvre une VRAIE fenêtre Chromium (on voit l'agent agir) ; défaut
# headless (serveur/démo/Cloud Run). MIRA_CU_SLOWMO (ms) force la vitesse des gestes
# (défaut 250 ms en headed). Usage : MIRA_HEADED=1 bash dev.sh
MIRA_HEADED=
MIRA_CU_SLOWMO=

# Périmètre du Locator (G-2/G-12). ⚠️ Variable de SHELL/dev.sh, PAS lue depuis ce
# fichier (c'est une politique de périmètre, pas un secret). Défaut du code =
# "localhost,127.0.0.1" ; dev.sh l'ouvre à "*" (web entier) pour crawler les vraies
# URLs. Re-verrouiller : MIRA_CU_ALLOWED_HOSTS="instagram.com,x.com" bash dev.sh
# MIRA_CU_ALLOWED_HOSTS=*

# Mode du Locator (Stage 1). Défaut PROD = "cu" (agent Gemini Computer Use : franchit
# les logins JS et atteint les vraies URLs). "crawl" = Playwright pur, rapide/déterministe
# mais bloqué par tout login. "mock" = candidat synthétique (tests / démo CLI stdlib).
# MIRA_LOCATOR_MODE=cu
# Cible par défaut si la victime ne soumet pas d'URL (G-12 : mock host servi par mira/web).
# MIRA_DEMO_SCOPE_URL=http://127.0.0.1:8001/mockhost/
# Point de DÉPART du crawl si différent du périmètre (ex. démarrer derrière un login JS) —
# le périmètre G-2 reste MIRA_DEMO_SCOPE_URL ; is_in_scope filtre chaque image en aval.
# MIRA_LOCATOR_START_URL=http://127.0.0.1:8001/mockhost/profil.html

# Stage 2 — détecteur de média synthétique (deepfake)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
DEEPFAKE_SCORE_THRESHOLD=0.85

# Stage 3 — dispatch RÉEL de la notice via Resend (vers l'inbox de démo uniquement, G-12).
# Sans RESEND_API_KEY ou sans MIRA_DEMO_INBOX -> fallback event (NOTIFIED sans envoi).
RESEND_API_KEY=
# Inbox de démo (destinataire). Compte Resend en mode test -> ce DOIT être l'e-mail du
# compte. Domaine vérifié -> n'importe quelle inbox de démo.
MIRA_DEMO_INBOX=
# Expéditeur. Défaut = onboarding@resend.dev (marche sans domaine vérifié). Domaine
# vérifié -> MIRA_RESEND_FROM=notices@ton-domaine.eu
# MIRA_RESEND_FROM=
NOTICE_SENDER_EMAIL=notice@exemple.eu

# Preuve / rétention (RGPD)
# EVIDENCE_ENCRYPTION_KEY : base64, 32 octets (openssl rand -base64 32).
# Chiffre le store du face-verifier au repos (AES-256-GCM, G-5).
# Absente : clé éphémère par process — jamais de clair sur disque, mais les
# données ne survivent pas à un restart (suffisant en dev/démo locale).
EVIDENCE_ENCRYPTION_KEY=
EVIDENCE_RETENTION_DAYS=90

# DB — Supabase (projet équipe ; valeurs via le Discord, jamais sur git)
# URL + clés : dashboard Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Clé secrète — côté SERVEUR uniquement, jamais exposée au front/navigateur.
SUPABASE_SERVICE_ROLE_KEY=
# Connexion Postgres directe (migrations, psql) : Settings → Database. Optionnel.
SUPABASE_DB_URL=

# Grok (xAI) — nudity/intent reasoning (mira/vision.ask_grok)
XAI_API_KEY=
