# Copie ce fichier en .env.local (jamais commité — voir .gitignore).
# Partage les vraies valeurs via le Discord équipe, PAS sur git.
# Le squelette (mocks) tourne SANS aucune de ces clés.

# LLM — rédaction de la notice DSA / instructions du locator
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Stage 1 — Locator RÉEL « computer use » (mira/locator_cu.py). Absent -> mock inchangé.
MIRA_LOCATOR_REAL=              # 1 pour activer Gemini CU + Playwright (hors MIRA_DEMO_MODE)
GEMINI_API_KEY=                 # clé Google AI Studio (cerveau Gemini 2.5 Computer Use)
GOOGLE_GENAI_USE_VERTEXAI=      # 1 pour passer par Vertex AI au lieu d'AI Studio
GOOGLE_CLOUD_PROJECT=           # requis si Vertex
GOOGLE_CLOUD_LOCATION=          # requis si Vertex (ex: us-central1)
MIRA_GEMINI_CU_MODEL=           # override du modèle (défaut: gemini-2.5-computer-use-preview-10-2025)
MIRA_LOCATOR_TEST_URL=          # mock host joignable pour le go/no-go (ou --url)

# Stage 2 — détecteur de média synthétique (deepfake)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
DEEPFAKE_SCORE_THRESHOLD=0.85

# Stage 3 — dispatch de la notice (vers l'inbox de démo uniquement)
RESEND_API_KEY=
SENDGRID_API_KEY=
NOTICE_SENDER_EMAIL=notice@exemple.eu
DEMO_TARGET_INBOX=

# Preuve / rétention (RGPD)
EVIDENCE_ENCRYPTION_KEY=
EVIDENCE_RETENTION_DAYS=90
