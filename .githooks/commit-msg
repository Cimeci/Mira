#!/bin/sh
# commit-msg — impose le format Conventional Commits.
#   <type>(scope): message      (scope optionnel)
#   types : feat fix chore refactor docs test perf ci
# Laisse passer les merges/reverts/fixup auto de git.

msg_file="$1"
first_line=$(head -n1 "$msg_file")

case "$first_line" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*) exit 0 ;;
esac

pattern='^(feat|fix|chore|refactor|docs|test|perf|ci)(\([a-z0-9._-]+\))?!?: .+'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  echo "✋ Message de commit non conforme :" >&2
  echo "   \"$first_line\"" >&2
  echo "" >&2
  echo "   Format attendu : <type>(scope): message" >&2
  echo "   types : feat, fix, chore, refactor, docs, test, perf, ci" >&2
  echo "   exemple :  feat(l1): mandate consent gate" >&2
  exit 1
fi

exit 0
