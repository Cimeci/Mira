# Frontend Mira — variables publiques (aucun secret ici, template pour frontend/.env.local).
# NEXT_PUBLIC_* = exposé au navigateur : l'anon key est faite pour ça (RLS côté DB).
# Ne JAMAIS mettre la SERVICE_ROLE_KEY ici.

# Supabase (auth session) — mêmes valeurs que SUPABASE_URL / SUPABASE_ANON_KEY du .env.local racine
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL du backend FastAPI (SSE live agent view). Vide = même origine.
# Ex en dev : http://localhost:8000
NEXT_PUBLIC_API_BASE=

# Force le face-scan en mode démo scripté (sans webcam) — projecteur / booth de jury.
# 1 = actif. Laisser vide en usage normal (fallback auto pour les iframes sandbox).
NEXT_PUBLIC_FACE_DEMO=
