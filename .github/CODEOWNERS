# Ownership par lane — remplacer @handle par les pseudos GitHub samedi matin.
# Une PR touchant un dossier notifie automatiquement son owner pour relecture.

# L1 — Core / Agent
/src/core/         @handle-l1
/src/agent/        @handle-l1

# L2 — Backend / API / Data
/src/app/api/      @handle-l2
/src/lib/          @handle-l2

# L3 — Frontend / UI
/src/components/   @handle-l3

# L4 — Infra / Deploy / DX  (garde main vert)
/.github/          @handle-l4
/setup.sh          @handle-l4
/*.config.*        @handle-l4

# L5 — Intégration / Démo / Pitch
/demo/             @handle-l5
/DEMO.md           @handle-l5
